{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legal-ai-prompts.otg.ai/schemas/pack.schema.json",
  "title": "Legal Prompt Workflow Pack",
  "description": "Schema for workflow pack manifests that chain prompts into a DAG.",
  "type": "object",
  "required": ["pack_id", "name", "version", "entry_step", "terminal_steps", "steps"],
  "additionalProperties": false,
  "properties": {
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{3,40}$",
      "description": "Unique pack identifier"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$"
    },
    "jurisdictions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entry_step": {
      "type": "string",
      "description": "ID of the first step in the workflow"
    },
    "terminal_steps": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "IDs of final steps that produce the workflow output"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "prompt_id"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,40}$"
          },
          "prompt_id": {
            "type": "string",
            "pattern": "^LP-V[1-8]-[A-Z]{2,4}-\\d{4}$"
          },
          "output_schema": {
            "type": "string",
            "pattern": "^schemas/.+\\.schema\\.json$"
          },
          "inputs_from": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step", "path"],
              "additionalProperties": false,
              "properties": {
                "step": { "type": "string" },
                "path": { "type": "string", "description": "JSONPath into predecessor output" }
              }
            }
          },
          "required_tools": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
